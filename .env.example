NODE_ENV=production
APP_ORIGIN=https://example.com
TRUST_PROXY=1
CHAT_AUTH_SECRET=replace-with-at-least-32-random-characters
CHAT_DATABASE_PATH=/var/lib/sensual-touches/support.sqlite
BOOKING_TIMEZONE_OFFSET=-04:00
BOOKING_MIN_LEAD_MINUTES=30
# Generate hashes by piping a password into: npm run hash-password
AGENT_ACCOUNTS=[{"id":"lotus","name":"Sasha","passwordHash":"scrypt$generated-salt$generated-hash"},{"id":"support-two","name":"Britney","passwordHash":"scrypt$generated-salt$generated-hash"}]

CASHAPP_PAYMENT_DESTINATION=replace-me
VENMO_PAYMENT_DESTINATION=replace-me
BITCOIN_PAYMENT_DESTINATION=replace-me
ZELLE_PAYMENT_DESTINATION=replace-me
APPLE_PAY_PAYMENT_DESTINATION=replace-me
CHIME_PAYMENT_DESTINATION=replace-me
PAYPAL_PAYMENT_DESTINATION=replace-me
